# ===== 河南方言语音板 · 环境变量模板 =====
# 复制本文件为 .env，填入你自己的密钥后启动服务。
# 注意：.env 已被 .gitignore 忽略，切勿提交到公开仓库！

# ---------- 讯飞开放平台（方言语音识别 ASR）----------
# 控制台 https://console.xfyun.cn → 创建"WebAPI"应用 → 添加"语音听写(流式版)"
# accent 固定为 henan（河南话）。下方三项必填，否则 ASR 不可用（前端会自动切示例模式）。
XF_APPID=你的讯飞APPID
XF_API_KEY=你的讯飞APIKey
XF_API_SECRET=你的讯飞APISecret

# ---------- 大模型 API（普通话/拼音/释义）----------
# 二选一即可：DeepSeek（便宜、中文强）或 通义千问（有免费额度）
# DeepSeek：https://platform.deepseek.com  通义千问：https://dashscope.aliyun.com
LLM_API_KEY=你的大模型APIKey
# 默认 DeepSeek；若用通义千问改成 https://dashscope.aliyun.com/compatible-mode/v1
LLM_BASE_URL=https://api.deepseek.com
# DeepSeek 用 deepseek-chat；通义千问用 qwen-plus / qwen-max
LLM_MODEL=deepseek-chat

# ---------- 本地离线识别（可选，FunASR，隐私零上传）----------
# 留空则用默认 paraformer-large 模型；若你自己训练/微调了河南话模型，可填其 ModelScope 路径。
# 例：iic/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-pytorch
OFFLINE_ASR_MODEL=

# ---------- 识别引擎选择（v2.0）----------
# 默认 auto：有讯飞密钥走云端；否则若 assets/asr_models/ 下已放 FunASR-ONNX 模型则走本地离线；
# 再否则若已 pip install funasr 则走本地 torch 版。
# 可选值：
#   auto        —— 按可用度自动（默认）
#   xunfei      —— 强制云端讯飞（需上方三项密钥）
#   offline     —— 强制本地离线 FunASR-ONNX（零上传，需离线模型）
#   funasr      —— 强制本地 torch 版 FunASR
ASR_ENGINE=auto

# 离线 ONNX 模型目录（可选）。留空则自动在 assets/asr_models/ 下查找含
# *.onnx + tokens.txt + am.mvn 的子目录（即打包内置的 Paraformer 模型）。
OFFLINE_ASR_MODEL_DIR=

# ---------- 服务配置 ----------
# 仅本机访问即可；如需局域网调试可改成 0.0.0.0（勿暴露到公网）
HOST=127.0.0.1
PORT=5000
